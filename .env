# URL del backend StockFlow (modo local)
VITE_API_URL=http://localhost:4000

# Nombre de la tienda
VITE_STORE_NAME=StockFlow Tienda

# Google OAuth — obtener en: https://console.cloud.google.com
# Dejá vacío para deshabilitar el login con Google temporalmente
VITE_GOOGLE_CLIENT_ID=

# Facebook OAuth — obtener en: https://developers.facebook.com
# Dejá vacío para deshabilitar el login con Facebook temporalmente
VITE_FACEBOOK_APP_ID=

# Stripe — obtener en: https://dashboard.stripe.com
# Dejá vacío para deshabilitar el pago con tarjeta temporalmente
VITE_STRIPE_PUBLIC_KEY=

# Datos bancarios para pago por transferencia
# Completar con el CBU/CVU real y el alias de la cuenta
VITE_TRANSFER_CBU=
VITE_TRANSFER_ALIAS=
