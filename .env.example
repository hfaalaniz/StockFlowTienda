# URL del backend StockFlow
VITE_API_URL=http://localhost:4000

# Google OAuth (obtener en https://console.cloud.google.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Stripe (obtener en dashboard.stripe.com)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Facebook OAuth (obtener en developers.facebook.com)
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# Nombre de la tienda
VITE_STORE_NAME=StockFlow Tienda

# Datos bancarios para transferencia (mostrados en checkout y confirmación)
VITE_TRANSFER_CBU=0000000000000000000000
VITE_TRANSFER_ALIAS=STOCKFLOW.TIENDA
